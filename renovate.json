{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "schedule": ["before 6am on Monday"],
  "timezone": "UTC",
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "all patches",
      "automerge": false
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchPackagePatterns": [
        "^@radix-ui/",
        "^lucide-react",
        "^tailwind",
        "^@tailwindcss/",
        "^next-themes",
        "^sonner"
      ],
      "groupName": "ui & styling minors"
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchPackagePatterns": [
        "^@supabase/",
        "^@sentry/",
        "^posthog-",
        "^resend",
        "^stripe",
        "^web-push",
        "^@upstash/"
      ],
      "groupName": "infra & vendor minors"
    },
    {
      "matchUpdateTypes": ["minor"],
      "matchPackagePatterns": [
        "^@testing-library/",
        "^@vitejs/",
        "^@vitest/",
        "vitest",
        "^@playwright/",
        "^playwright"
      ],
      "groupName": "test stack minors",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "groupName": "majors (review one-by-one)",
      "addLabels": ["major-update"],
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchPackageNames": ["next", "react", "react-dom"],
      "groupName": "next + react (lockstep)"
    },
    {
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "schedule": "at any time",
    "automerge": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on Sunday"]
  }
}
